# Environment Configuration Template
# Copy this file to .env and update values for your environment

# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database Configuration
POSTGRES_URL=postgresql://scraper:password@localhost:5432/business_scraper
POSTGRES_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Browser Pool Configuration
BROWSER_POOL_MIN_INSTANCES=2
BROWSER_POOL_MAX_INSTANCES=10
BROWSER_POOL_IDLE_TIMEOUT=300000
BROWSER_POOL_MAX_REQUESTS_PER_INSTANCE=100

# Cache Configuration
CACHE_DEFAULT_TTL=3600
CACHE_MAX_MEMORY=512mb
CACHE_EVICTION_POLICY=allkeys-lru
CACHE_BACKGROUND_REFRESH_THRESHOLD=0.8

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_QUEUE_MAX_SIZE=1000

# Performance Configuration
PERFORMANCE_RESPONSE_TIME_THRESHOLD_MS=3000
PERFORMANCE_CACHE_RESPONSE_TIME_THRESHOLD_MS=200
PERFORMANCE_CONCURRENT_REQUEST_SUCCESS_RATE=0.8

# Resource Blocking Configuration
RESOURCE_BLOCKING_ENABLED=true
RESOURCE_BLOCKING_IMAGES=true
RESOURCE_BLOCKING_CSS=true
RESOURCE_BLOCKING_FONTS=true
RESOURCE_BLOCKING_WHITELIST=

# Monitoring Configuration
MONITORING_ENABLED=true
MONITORING_METRICS_INTERVAL_MS=10000
MONITORING_ALERT_WEBHOOK_URL=

# Security Configuration
API_KEY_REQUIRED=false
API_KEY=
CORS_ORIGIN=*
HELMET_ENABLED=true

# Scraping Configuration
SCRAPING_USER_AGENT=BusinessDataScraperV2/1.0
SCRAPING_TIMEOUT_MS=30000
SCRAPING_RETRY_ATTEMPTS=3
SCRAPING_RETRY_DELAY_MS=1000

# Fallback Configuration
FALLBACK_ENABLED=true
FALLBACK_MAX_ATTEMPTS=3
FALLBACK_STALE_DATA_MAX_AGE_MS=86400000