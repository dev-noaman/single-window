# ===========================================
# Qatar Investor Portal Scrapers - Environment Template
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# ===========================================
# Evolution API (WhatsApp Business API)
# PostgreSQL + Redis run as Docker containers in the same network
# Only API key needs customization; DB is hardcoded in docker-compose.yml
# ===========================================
EVOLUTION_SERVER_URL=https://noaman.cloud/evolution
EVOLUTION_API_KEY=your-secure-api-key-here

# ===========================================
# BillionMail (Email Server + Marketing)
# Installed separately at /opt/BillionMail with its own .env
# See: https://github.com/aaPanel/BillionMail
# ===========================================

# ===========================================
# API-CR (Company Search)
# ===========================================
# These are in API-CR/data/.env - included here for reference
# USER_QID=your-qatar-id
# USER_PASSWORD=your-portal-password

# ===========================================
# OfficeRnD
# ===========================================
# These are in officernd/config/.env - included here for reference
# OFFICERND_API_URL=http://localhost:8087
# OFFICERND_ACCESS_TOKEN=your-token

# ===========================================
# Portal (no secrets needed)
# ===========================================
# Portal uses nginx + PHP, no environment secrets
