# ===========================================
# Qatar Investor Portal Scrapers - Environment Template
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# ===========================================
# Evolution API (WhatsApp Business API)
# ===========================================
EVOLUTION_SERVER_PORT=8080
EVOLUTION_SERVER_URL=https://noaman.cloud/evolution
EVOLUTION_API_KEY=your-secure-api-key-here
EVOLUTION_DATABASE_PROVIDER=postgresql
EVOLUTION_DATABASE_URI=postgresql://evolution_user:your-password@host.docker.internal:5432/evolutiondb?schema=evolution_api
EVOLUTION_CACHE_REDIS_ENABLED=true
EVOLUTION_CACHE_REDIS_URI=redis://evolution-redis:6379/6
EVOLUTION_DATABASE_SAVE_DATA_INSTANCE=true
EVOLUTION_DATABASE_SAVE_DATA_NEW_MESSAGE=true
EVOLUTION_DATABASE_SAVE_MESSAGE_UPDATE=true
EVOLUTION_DATABASE_SAVE_DATA_CONTACTS=true
EVOLUTION_DATABASE_SAVE_DATA_CHATS=true

# ===========================================
# BillionMail (Email Server + Marketing)
# ===========================================
BILLIONMAIL_HOSTNAME=noaman.cloud
BILLIONMAIL_ADMIN_USERNAME=admin
BILLIONMAIL_ADMIN_PASSWORD=your-secure-password-here
BILLIONMAIL_SAFEPATH=your-random-safepath-here
BILLIONMAIL_DBPASS=your-db-password-here
BILLIONMAIL_REDISPASS=your-redis-password-here
BILLIONMAIL_TZ=Asia/Qatar

# ===========================================
# API-CR (Company Search)
# ===========================================
# These are in API-CR/data/.env - included here for reference
# USER_QID=your-qatar-id
# USER_PASSWORD=your-portal-password

# ===========================================
# OfficeRnD
# ===========================================
# These are in officernd/config/.env - included here for reference
# OFFICERND_API_URL=http://localhost:8087
# OFFICERND_ACCESS_TOKEN=your-token

# ===========================================
# Portal (no secrets needed)
# ===========================================
# Portal uses nginx + PHP, no environment secrets
